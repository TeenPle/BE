SPRING_PROFILES_ACTIVE=prod
SERVER_ADDRESS=127.0.0.1
SERVER_PORT=8080

DB_URL=jdbc:mysql://RDS_ENDPOINT:3306/teenple?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=teenple
DB_PASSWORD=CHANGE_ME
DB_DRIVER=com.mysql.cj.jdbc.Driver
JPA_DDL_AUTO=validate

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

JWT_SECRET=CHANGE_TO_AT_LEAST_32_RANDOM_BYTES
JWT_ACCESS_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=1209600000

MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_FROM=CHANGE_ME

CORS_ALLOWED_ORIGINS=https://api.teenple.app
WS_ALLOWED_ORIGINS=https://api.teenple.app

AWS_REGION=ap-northeast-2
FILE_BUCKET=teenple-media
FILE_STUDENT_CARD_BUCKET=teenple-student-card
FILE_STUDENT_CARD_DIR=student-card
FILE_CHAT_DIR=chat
FILE_POST_DIR=post
FILE_BASE_URL=https://teenple-media.s3.ap-northeast-2.amazonaws.com

FIREBASE_SERVICE_ACCOUNT_PATH=/opt/teenple/secrets/firebase-service-account.json
NEIS_API_KEY=CHANGE_ME
LOG_PATH=/var/log/teenple
